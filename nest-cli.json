{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "**/migrations/*.ts",
        "watchAssets": true
      },
      {
        "include": "config/db/*.ts",
        "watchAssets": true
      }
    ]
  }
}
